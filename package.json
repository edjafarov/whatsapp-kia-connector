{
  "name": "whatsapp-kia-connector",
  "version": "1.0.0",
  "description": "WhatsApp connector for alpha-cent / KIAgent (Baileys-based, self-contained).",
  "license": "MIT",
  "private": false,
  "files": [
    "dist",
    "manifest.json"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "pack": "npm run build && npm pack"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "6.7.23",
    "adm-zip": "^0.5.17",
    "whatsapp-chat-parser": "^4.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "better-sqlite3": "^11.0.0",
    "esbuild": "0.23.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest",
      "node_modules/@whiskeysockets/baileys/.+\\.js$": "<rootDir>/jest/esm-cjs-transformer.cjs"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@whiskeysockets/baileys)/)"
    ]
  }
}
